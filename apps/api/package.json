{
  "name": "@onboarding/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:env": "tsx src/config/env.validation.ts",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate:dry": "prisma migrate diff --from-empty --to-schema-datamodel src/prisma/schema.prisma --script",
    "prisma:migrate:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "prisma:seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/csrf-protection": "^7.0.2",
    "@google/generative-ai": "^0.21.0",
    "@onboarding/schemas": "workspace:*",
    "@onboarding/types": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^6.1.0",
    "@react-pdf/renderer": "^4.1.6",
    "@supabase/supabase-js": "^2.47.10",
    "@t3-oss/env-core": "^0.11.1",
    "bcryptjs": "^2.4.3",
    "class-sanitizer": "^1.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "nestjs-zod": "^4.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.1",
    "rxjs": "^7.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
