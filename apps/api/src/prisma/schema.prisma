generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id         String             @id @default(uuid())
  name       String
  createdAt  DateTime           @default(now())
  recruiters Recruiter[]
  joinees    Joinee[]
  templates  DocumentTemplate[]
}

model Recruiter {
  id             String             @id @default(uuid())
  supabaseUserId String             @unique
  email          String             @unique
  role           RecruiterRole      @default(RECRUITER)
  orgId          String
  org            Organisation       @relation(fields: [orgId], references: [id])
  createdAt      DateTime           @default(now())
  joinees        Joinee[]
  templates      DocumentTemplate[]
  auditLogs      AuditLog[]
}

model Joinee {
  id            String           @id @default(uuid())
  displayId     String           @unique
  orgId         String
  org           Organisation     @relation(fields: [orgId], references: [id])
  recruiterId   String
  recruiter     Recruiter        @relation(fields: [recruiterId], references: [id])
  importBatchId String?
  status        JoineeStatus     @default(PENDING)
  templateId    String
  template      DocumentTemplate @relation(fields: [templateId], references: [id])
  submission    Submission?
  accessCodeHash String
  createdAt     DateTime         @default(now())
}

model DocumentTemplate {
  id            String         @id @default(uuid())
  name          String
  version       Int            @default(1)
  orgId         String
  org           Organisation   @relation(fields: [orgId], references: [id])
  recruiterId   String
  recruiter     Recruiter      @relation(fields: [recruiterId], references: [id])
  mandatoryDocs MandatoryDoc[]
  fields        TemplateField[]
  pages         TemplatePage[]
  joinees       Joinee[]
  createdAt     DateTime       @default(now())
  archivedAt    DateTime?
}

model MandatoryDoc {
  id         String           @id @default(uuid())
  label      String
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id])
}

model TemplateField {
  id           String           @id @default(uuid())
  label        String
  fieldType    FieldType
  defaultValue String?
  required     Boolean          @default(true)
  skipNote     String?
  order        Int
  templateId   String
  template     DocumentTemplate @relation(fields: [templateId], references: [id])
}

model TemplatePage {
  id         String           @id @default(uuid())
  order      Int
  sourceUrl  String
  templateId String
  template   DocumentTemplate @relation(fields: [templateId], references: [id])
}

model Submission {
  id             String        @id @default(uuid())
  joineeId       String        @unique
  joinee         Joinee        @relation(fields: [joineeId], references: [id])
  fieldValues    Json
  uploadedDocs   UploadedDoc[]
  signatureUrl   String?
  signedPdfUrl   String?
  unsignedPdfUrl String?
  ipAddress      String
  signedAt       DateTime?
  consentGiven   Boolean       @default(false)
  completedAt    DateTime?
}

model UploadedDoc {
  id           String     @id @default(uuid())
  label        String
  storageUrl   String
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  uploadedAt   DateTime   @default(now())
}

model AuditLog {
  id          String     @id @default(uuid())
  recruiterId String?
  recruiter   Recruiter? @relation(fields: [recruiterId], references: [id])
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime   @default(now())
}

enum RecruiterRole {
  ADMIN
  RECRUITER
}

enum JoineeStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum FieldType {
  TEXT
  MULTISELECT
  BULLET
}
